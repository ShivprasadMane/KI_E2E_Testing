{
  "name": "keyinvest-e2e",
  "version": "1.0.0",
  "description": "KeyInvest portal E2E tests (test environment)",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "validate:matrix": "npx tsx scripts/validate-matrix.ts",
    "test:matrix": "node scripts/run-matrix-grouped.js",
    "test:matrix:headed": "node scripts/run-matrix-grouped.js --headed",
    "test:matrix:raw": "node scripts/run-matrix.js",
    "test:matrix:grouped": "node scripts/run-matrix-grouped.js",
    "test:matrix:grouped:headed": "node scripts/run-matrix-grouped.js --headed",
    "test:matrix:funeral": "node scripts/run-matrix-funeral.js",
    "test:matrix:funeral:headed": "node scripts/run-matrix-funeral.js --headed",
    "matrix:plan": "npx tsx scripts/matrix-plan.ts",
    "matrix:generate": "npx tsx scripts/generate-login-matrix.ts",
    "test:create-application": "playwright test --project=matrix-create-application",
    "test:create-application:headed": "playwright test --project=matrix-create-application --headed",
    "test:create-application:specs": "playwright test --grep @create-application",
    "test:login": "playwright test --project=login",
    "test:login:headed": "playwright test --project=login --headed",
    "test:login:guest": "playwright test --project=login --grep @login-guest",
    "test:login:guest:headed": "playwright test --project=login --grep @login-guest --headed",
    "test:login:investor": "playwright test --project=login --grep @login-investor",
    "test:login:investor:headed": "playwright test --project=login --grep @login-investor --headed",
    "test:login:funeral": "playwright test --project=login --grep @login-funeral",
    "test:login:funeral:headed": "playwright test --project=login --grep @login-funeral --headed",
    "test:login:adviser": "playwright test --project=login --grep @login-adviser",
    "test:login:adviser:headed": "playwright test --project=login --grep @login-adviser --headed",
    "test:login:admin": "playwright test --project=login --grep @login-admin",
    "test:login:admin:headed": "playwright test --project=login --grep @login-admin --headed",
    "test:login:invalid": "playwright test --project=login --grep @login-invalid",
    "test:smoke": "playwright test --project=smoke",
    "test:guest": "playwright test --project=guest",
    "test:investor": "playwright test --project=investor",
    "test:funeral": "playwright test --project=funeral",
    "test:funeral:links": "playwright test --project=funeral --grep @funeral-links",
    "test:funeral:links:headed": "playwright test --project=funeral --grep @funeral-links --headed",
    "test:funeral:export": "playwright test --project=funeral --grep @funeral-export",
    "test:funeral:export:headed": "playwright test --project=funeral --grep @funeral-export --headed",
    "test:funeral:portfolio": "playwright test --project=funeral --grep @funeral-portfolio",
    "test:funeral:recent-app": "playwright test --project=funeral --grep @funeral-recent-app",
    "test:funeral:summary-filters": "playwright test --project=funeral --grep @funeral-summary-filters",
    "test:adviser": "playwright test --project=adviser",
    "test:adviser:export": "playwright test --project=adviser --grep @adviser-export",
    "test:adviser:export:headed": "playwright test --project=adviser --grep @adviser-export --headed",
    "test:admin": "playwright test --project=admin",
    "test:setup": "playwright test --project=setup-guest --project=setup-investor --project=setup-funeral --project=setup-adviser --project=setup-admin",
    "test:setup:guest": "playwright test --project=setup-guest",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "codegen": "playwright codegen",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  }
}
